APP_NAME="Sistema de Calificaciones"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tu-app.up.railway.app
APP_KEY=base64:REEMPLAZA_CON_TU_APP_KEY

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=REEMPLAZA_CON_HOST_POSTGRES
DB_PORT=5432
DB_DATABASE=REEMPLAZA_CON_DATABASE
DB_USERNAME=REEMPLAZA_CON_USERNAME
DB_PASSWORD=REEMPLAZA_CON_PASSWORD

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

RUN_MIGRATIONS=true
RUN_DB_SEED=true
